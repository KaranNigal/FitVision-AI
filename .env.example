# PostgreSQL Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=fitvision
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres_secure_pass@db:5432/fitvision

# JWT Security Configuration
JWT_SECRET=super_secret_hex_key_change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Media and File Storage Configuration
MEDIA_STORAGE_PATH=/app/media
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Backend Details
HOST=0.0.0.0
PORT=8000
